{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GroundTruth Local",
  "version": "0.1.0",
  "identifier": "com.groundtruth.local",
  "build": {
    "beforeDevCommand": "pnpm --filter @groundtruth/frontend dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "pnpm --filter @groundtruth/frontend build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GroundTruth Local",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/sidecar"
    ]
  }
}
